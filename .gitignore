# ── Monorepo root gitignore ──

# macOS
.DS_Store
**/.DS_Store

# Env files (NEVER commit)
**/.env
**/.env.local
**/.env.production

# node_modules in any subfolder
**/node_modules/

# Next.js build outputs
**/.next/
**/out/
**/build/

# TypeScript build info
*.tsbuildinfo
**/next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# Backend runtime data
backend/promoted.json

# Cert files
*.pem
